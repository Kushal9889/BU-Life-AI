# NVIDIA NIM (main LLM + embeddings)
NVIDIA_API_KEY=nvapi-your-nvidia-nim-key
CHAT_MODEL=meta/llama-3.3-70b-instruct
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Groq (free, fast — used for query routing only)
GROQ_API_KEY=gsk_your-groq-key

DATABASE_URL=postgresql://localhost/bulife
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.netlify.app

# LangSmith (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_PROJECT=bulife-ai
